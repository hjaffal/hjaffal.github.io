rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Vocab progress: anyone can read (for leaderboard), only own doc writable by authenticated user
    match /vocab_progress/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // No client-side access for everything else — only Cloud Functions (admin SDK)
    match /subscribers/{doc} {
      allow read, write: if false;
    }
    match /editions/{doc} {
      allow read, write: if false;
    }
    match /events/{doc} {
      allow read, write: if false;
    }

    // Default deny for any other collection
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
