rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // No client-side access — only Cloud Functions (admin SDK) can read/write
    // Reports are accessed via secure token validated server-side
    match /{document=**} {
      allow read, write: if false;
    }

    // Newsletter collections: server-only access via Admin SDK
    match /subscribers/{doc} {
      allow read, write: if false;
    }
    match /editions/{doc} {
      allow read, write: if false;
    }
    match /events/{doc} {
      allow read, write: if false;
    }
  }
}
